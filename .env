# ═══ Vixor Environment Variables ═══
# NEVER commit actual secrets to version control.
# Use .env.local for local development (already git-ignored).
# Use Vercel/Supabase environment variables for production.

# Twelve Data API — Real-time forex rates, OHLCV, ETFs, fundamentals
# Get your free key at https://twelvedata.com/pricing
TWELVEDATA_API_KEY=

# Finnhub API — News & market data
FINNHUB_API_KEY=

# Gemini AI — Visual chart analysis
GEMINI_API_KEY=

# Lovable AI Gateway — Alternative AI endpoint
LOVABLE_AI_GATEWAY_KEY=

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# Telegram Webhook Secret — Prevents forged webhook events
# Set this in @BotFather when setting the webhook: /setwebhook?url=...&secret_token=YOUR_SECRET
# MUST match in Vercel env vars for production
TELEGRAM_WEBHOOK_SECRET=

# Cron Secret — Protects /api/check-alerts and /api/generate-signals
# Vercel Cron sends this as Authorization: Bearer <CRON_SECRET>
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Upstash Redis — Persistent caching across serverless invocations
# Get your free instance at https://upstash.com/pricing
# Optional: If not configured, in-memory cache is used as fallback
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
